    {
      "id": "list1_desc",
      "type": "text",
      "x": 665,
      "y": 435,
      "width": 470,
      "height": 120,
      "text": "One row per item on the PO.\nPre-populated from the PO detail lines.\n\nEach row shows what was ordered & what's\noutstanding, plus editable fields for what\nthe user is receiving/returning today.\n\nWhich tables give you this data?",
      "fontSize": 14,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#dbeafe",
      "opacity": 100,
      "seed": 200072
    },

