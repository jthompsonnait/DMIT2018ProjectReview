    {
      "id": "list2_desc",
      "type": "text",
      "x": 665,
      "y": 630,
      "width": 470,
      "height": 115,
      "text": "Starts EMPTY.\n\nItems the vendor shipped that were never\non the PO. The user adds these manually.\n\nThese never enter inventory — they get\nreturned as \"Incorrect item.\"",
      "fontSize": 14,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#374151",
      "opacity": 100,
      "seed": 200082
